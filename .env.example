# Primary “Join” destination for all CTAs (waitlist, form, external URL, or mailto:you@domain.com)
# If unset, buttons scroll to the #join section (bottom CTA).
# VITE_WAITLIST_URL=https://forms.example/waitlist

# Optional: full site origin with no trailing slash, for Open Graph meta in index.html
# VITE_SITE_URL=https://your-domain.com
